---
import { REPO_URL, SITE_NAME } from "../lib/site";
---

<header class="border-b border-border">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2.5">
      <img src="/images/logo.png" alt="" width="28" height="28" class="rounded-full" />
      <span class="font-semibold tracking-tight text-white">{SITE_NAME}</span>
    </a>

    <nav class="flex items-center gap-6">
      <a
        href="/#features"
        class="hidden text-sm text-fg-muted transition-colors hover:text-white sm:inline"
      >
        Features
      </a>
      <a
        href="/#download"
        class="hidden text-sm text-fg-muted transition-colors hover:text-white sm:inline"
      >
        Download
      </a>
      <a
        href={REPO_URL}
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md border border-border bg-bg-elevated px-3 py-1.5 text-sm font-medium text-fg transition-colors hover:border-zinc-500 hover:text-white"
      >
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
            0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
            -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
            .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
            -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0
            1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82
            1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01
            1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
        Star on GitHub
      </a>
    </nav>
  </div>
</header>
